DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,ecoverify-backend.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://eco-verify-mu.vercel.app
CSRF_TRUSTED_ORIGINS=https://ecoverify-backend.onrender.com,https://eco-verify-mu.vercel.app
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Use the Supabase pooler URL for local development because the direct database
# host may require IPv6. Copy it from Supabase Dashboard > Connect > Transaction pooler.
# The username normally looks like postgres.kbsldrdochhsmybpdxuj.
DATABASE_URL=postgresql://postgres.kbsldrdochhsmybpdxuj:YOUR-PASSWORD@YOUR-POOLER-HOST.pooler.supabase.com:6543/postgres
DB_SSLMODE=require
